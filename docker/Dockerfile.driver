# The "driver" plays the role of a developer's machine: it has the CLI, the
# compile engine, componentize-py, and a sample project, and it runs the
# end-to-end script against the server.
FROM ubuntu:24.04

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        python3 python3-venv python3-pip ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

# The compile engine binary (built on the host) and the WIT contract.
COPY sdk/target/release/tandem-compile /usr/local/bin/tandem-compile
COPY sdk/wit /opt/tandem/wit

# Install the CLI and the runtime SDK into a private venv. componentize-py comes
# in as a dependency of the CLI.
COPY cli /opt/tandem/cli
COPY sdk/python-sdk /opt/tandem/sdk-python
RUN python3 -m venv /opt/tandem/venv \
    && /opt/tandem/venv/bin/pip install --no-cache-dir \
        /opt/tandem/cli /opt/tandem/sdk-python

ENV PATH=/opt/tandem/venv/bin:$PATH
ENV TANDEM_COMPILE_BIN=/usr/local/bin/tandem-compile
ENV TANDEM_COMPONENTIZE_PY=/opt/tandem/venv/bin/componentize-py
ENV TANDEM_WIT_DIR=/opt/tandem/wit
ENV TANDEM_COMPILE_CACHE=/opt/tandem/cache
# The compute happens on the nodes, so the driver doesn't run a local node.
ENV TANDEM_SKIP_NODE_CHECK=1

COPY docker/sample /opt/tandem/sample
COPY docker/sample-serve /opt/tandem/sample-serve
COPY sdk/python-sdk/examples /opt/tandem/examples
COPY docker/e2e.sh /opt/tandem/e2e.sh
RUN chmod +x /opt/tandem/e2e.sh

WORKDIR /opt/tandem/sample
CMD ["/opt/tandem/e2e.sh"]
