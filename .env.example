# Database URL — SQLite is used automatically if left blank.
# For production Postgres, specify your connection string here.
DATABASE_URL=postgresql://tandem:tandem@127.0.0.1:5432/tandem

# Redis connection URL — required for task queueing and node heartbeats.
REDIS_URL=redis://127.0.0.1:6379/0

# Storage folder for compiled task artifacts.
TASK_STORAGE_ROOT=runtime

# The address of the central Tandem server.
TANDEM_SERVER_URL=https://tandem.wnusair.org
TANDEM_API_KEY=
# TANDEM_VERIFY_SAMPLE_PERCENT=10
# TANDEM_VERIFY_COPIES=3
# TANDEM_VERIFY_TIMEOUT_SECONDS=300
