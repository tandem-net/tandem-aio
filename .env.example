DATABASE_URL=postgresql://tandem:tandem@127.0.0.1:5432/tandem
REDIS_URL=redis://127.0.0.1:6379/0
TASK_STORAGE_ROOT=runtime
# Optional shared token for headless nodes with no account. Logged-in users
# don't need it. Left unset, the server generates a random one on first run
# (server/keys/node_registration_token.txt). Set it for a fixed value.
# TANDEM_NODE_REGISTRATION_TOKEN=meow-secret
TANDEM_SERVER_URL=http://127.0.0.1:6767
TANDEM_API_KEY=
TANDEM_NODE_BENCHMARK_STARTUP=0
TANDEM_TASK_TIMEOUT_SECS=300
TANDEM_NODE_PYTHON=python3
