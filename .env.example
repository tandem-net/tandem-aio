# Database URL — SQLite is used automatically if left blank.
# For production Postgres, specify your connection string here.
DATABASE_URL=postgresql://tandem:tandem@127.0.0.1:5432/tandem

# Redis connection URL — required for task queueing and node heartbeats.
REDIS_URL=redis://127.0.0.1:6379/0

# Storage folder for compiled task artifacts.
TASK_STORAGE_ROOT=runtime

# The address of the central Tandem server.
TANDEM_SERVER_URL=http://127.0.0.1:6767

# Optional: Shared token for headless worker nodes with no account.
# If left commented out, the server generates a random one on first run
# and saves it to server/keys/node_registration_token.txt.
# TANDEM_NODE_REGISTRATION_TOKEN=meow-secret

# Optional: Custom paths for the JWT keys.
# JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
# JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem

# Note: Do NOT store TANDEM_API_KEY in this file. The CLI saves user credentials
# securely in your operating system's password manager (keyring) automatically.
