DATABASE_URL=postgresql://tandem:tandem@127.0.0.1:5432/tandem
REDIS_URL=redis://127.0.0.1:6379/0
TASK_STORAGE_ROOT=runtime
# Optional shared token for headless nodes that have no user account. You can
# almost always leave this unset: anyone who runs `tandem auth login` registers
# their node under their own account, no token needed. Left unset, the server
# still generates + persists a random fallback on first run (see
# server/keys/node_registration_token.txt). Only set this if you want a fixed,
# predictable value for headless nodes.
# TANDEM_NODE_REGISTRATION_TOKEN=meow-secret
TANDEM_SERVER_URL=http://127.0.0.1:6767
TANDEM_API_KEY=
TANDEM_NODE_BENCHMARK_STARTUP=0
TANDEM_TASK_TIMEOUT_SECS=300
TANDEM_NODE_PYTHON=python3
