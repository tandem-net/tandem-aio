package tandem:task@0.1.0;

// The contract every Tandem task component implements, whatever language it was
// written in. The CLI compiles a user's marked function into a component that
// exports `run`; the node loads that component and calls `run` with the task's
// JSON-encoded input, then ships back the JSON-encoded result.
//
// This is a bundled copy of sdk/wit/task.wit so the packaged CLI can find it
// without the rest of the repo present. Keep the two in sync.
world task {
    export run: func(input: list<u8>) -> list<u8>;
}
