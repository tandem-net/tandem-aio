{
  "name": "@tandem/cli",
  "version": "0.1.0",
  "description": "Tandem build CLI -- scans projects, validates task metadata, bundles it into a .tandem artifact, and uploads it to the server.",
  "type": "module",
  "bin": {
    "tandem": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "fast-glob": "^3.3.2",
    "adm-zip": "^0.5.10",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "tsx": "^4.7.2",
    "vitest": "^1.5.0",
    "@types/node": "^20.12.7",
    "@types/adm-zip": "^0.5.5"
  },
  "engines": {
    "node": ">=18"
  }
}
