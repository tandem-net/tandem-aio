{
  // Hide generated artifacts from Zed's file tree and searches.
  // Note: file_scan_exclusions overrides Zed's defaults, so we keep them here too.
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/__pycache__",
    "sdk/.build",
    "sdk/wit_world",
    "sdk/componentize_py_async_support",
    "sdk/componentize_py_runtime.pyi",
    "sdk/componentize_py_types.py",
    "sdk/poll_loop.py",
  ],
  "file_scan_inclusions": [".env*", "sdk/**/*.wasm"],
}
